# Copy to .env and fill in your Browserbase credentials.

# Required — from your Browserbase dashboard.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Ceiling on concurrent Browserbase sessions, matching your plan's
# "concurrent browsers" limit (25 = Developer, 100 = Startup).
BROWSERBASE_MAX_CONCURRENCY=25

# Comma-separated case numbers to scrape directly, bypassing enumeration.
# Recommended for a quick demo — the default sweep probes sequence numbers
# from 00001 and most are empty.
LA_CASE_NUMBERS=19STCV12345

# Stop after this many cases yield documents.
LA_MAX_CASES=50

# Documents downloaded per case; 0/unset = every document in the case.
LA_MAX_DOCS=0

# Parallel worker sessions probing/scraping cases (one Browserbase session
# each). 16 is the measured sweet spot; more overloads the captcha solver.
LA_CONCURRENCY=16
